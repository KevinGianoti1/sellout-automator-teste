# ============================================
# Configuração de RD Station
# ============================================

# Sua chave de API do RD Station
# Obtenha em: https://app.rdstation.com.br/admin/settings/api
RD_STATION_API_KEY=sua_api_key_aqui

# ============================================
# Configuração de Email para Envio de Relatórios
# ============================================

# Email que receberá os relatórios diários
EMAIL_DESTINO=analista.vendas@mfferramentas.com.br

# Email de remetente (aquele que enviará os relatórios)
EMAIL_USER=seu_email@gmail.com

# Senha do email (ou senha de app se usar Gmail)
# Para Gmail: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=sua_senha_aqui

# Servidor SMTP
# Gmail: smtp.gmail.com
# Outlook: smtp-mail.outlook.com
# Hotmail: smtp.hotmail.com
SMTP_SERVER=smtp.gmail.com

# Porta SMTP (geralmente 587 para TLS)
SMTP_PORT=587

# ============================================
# Configurações Opcionais
# ============================================

# Horário da execução diária (0-23)
RELATORIO_HORA=8

# Minuto da execução diária (0-59)
RELATORIO_MINUTO=0
