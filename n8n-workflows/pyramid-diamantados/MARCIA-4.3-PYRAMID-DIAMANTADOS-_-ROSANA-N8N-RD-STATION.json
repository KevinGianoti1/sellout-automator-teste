      "id": "b5351a6d-e197-4df3-a94f-834cb8a76b0e",
      "name": "CRIAÇÃO NEGOCIAÇÃO",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        576,
        432
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst raw = $json;\nlet dealId = null;\n\ntry {\n  const body = raw.body ?? raw;\n  const dealBody = typeof body === 'string' ? JSON.parse(body) : body;\n  dealId = dealBody._id ?? dealBody.id ?? dealBody.deal?._id ?? dealBody.deal?.id;\n} catch(e) {}\n\nif (!dealId) dealId = raw._id ?? raw.id ?? null;\n\n// org_id: busca direta com try/catch — cobre tanto empresa nova quanto empresa existente\nlet orgId = null;\ntry { const v = $('EXTRAIR ORG ID NOVO').first().json.org_id; if (v) orgId = v; } catch(e) {}\nif (!orgId) {\n  try { const v = $('CHECAR EMPRESA EXISTE').first().json.org_id; if (v) orgId = v; } catch(e) {}\n}\n\nconst montagem = $('MONTAGEM NEGOCIAÇÃO').first().json;\n\nreturn [{json: {\n  deal_id:     dealId,\n  org_id:      orgId || montagem.org_id || null,\n  campaign_id: montagem.campaign_id,\n  source_id:   montagem.source_id,\n  contact_id:  montagem.contact_id\n}}];\n"
      },
