      "id": "99f58353-1159-4f5e-b7e7-82b26e83df9d",
      "name": "CRIAÇÃO CONTATO",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        96,
        432
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst lead      = $('VALIDAÇÃO CAMPOS').first().json;\nconst cnpjResp  = $('BUSCA CNPJ').first().json;\n\n// $json = output de CRIAÇÃO CONTATO\n// O RD retorna o contato com campo \"organization\" ou \"organization_id\"\nconst contBody  = $json.body ?? $json;\nconst contactId = contBody._id ?? contBody.id ?? contBody.contact?._id;\n\n// Razão social da Receita Federal\nconst razaoSocial = cnpjResp.body?.razao_social ?? cnpjResp.razao_social ?? lead.razao_social ?? '';\n\n// Org ID — pega do contato criado (RD retorna organization._id no response)\nlet orgId = null;\n\n// 1. Do retorno do contato criado (mais confiável — sempre presente)\norgId = contBody.organization?._id \n     ?? contBody.organization?.id\n     ?? contBody.organization_id\n     ?? null;\n\n// 2. Fallback: tenta CHECAR EMPRESA EXISTE\nif (!orgId) {\n  try { const v = $('CHECAR EMPRESA EXISTE').first().json.org_id; if (v) orgId = v; } catch(e) {}\n}\n\n// 3. Fallback: tenta EXTRAIR ORG ID NOVO\nif (!orgId) {\n  try { const v = $('EXTRAIR ORG ID NOVO').first().json.org_id; if (v) orgId = v; } catch(e) {}\n}\n\n// Fonte e Campanha — reutiliza valores já calculados em DEFINIR FONTE E CAMPANHA\nconst fonteCampanha = $('DEFINIR FONTE E CAMPANHA').first().json;\nconst source_id     = fonteCampanha.source_id;\nconst campaign_id   = fonteCampanha.campaign_id;\n\nconst cnaeAprovado = String(lead.cnae_status ?? 'Aprovado').toLowerCase().includes('aprov');\nconst dealName = `${lead.name} | ${razaoSocial} | ${lead.origem_anuncio || lead.origin}`;\n\nreturn [{json: {\n  ...lead,\n  razao_social:  razaoSocial,\n  contact_id:    contactId,\n  org_id:        orgId,\n  deal_name:     dealName,\n  source_id,\n  campaign_id,\n  pipeline_id:   '67a0f6fe0e4c890018795f0f',\n  stage_id:      '67a0f6fe0e4c890018795f12',\n  cnae_aprovado: cnaeAprovado\n}}];\n"
      },
