      "parameters": {
        "jsCode": "\nconst raw = String($json.origin ?? '').toLowerCase()\n  .normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n\nlet fonte = null, campanha = null, source_id = null, campaign_id = null;\n\nif (/site/.test(raw)) {\n  fonte = 'Site'; campanha = 'Google ADS';\n  source_id = '69669012a9c2ec001349e6df'; campaign_id = '6478e13d8f557c00188e4c7c';\n} else if (/instagram|facebook|ig|fb|redes?.?social/.test(raw)) {\n  fonte = 'Redes Sociais'; campanha = 'Tráfego Pago';\n  source_id = '66d74ce07d2f800014cb003c'; campaign_id = '64b82d4019f6fc001c8c89bb';\n} else if (/google/.test(raw)) {\n  fonte = 'Site'; campanha = 'Google ADS';\n  source_id = '69669012a9c2ec001349e6df'; campaign_id = '6478e13d8f557c00188e4c7c';\n}\n\nreturn [{json: {\n  ...$json,\n  fonte_crm:   fonte,\n  campanha_crm: campanha,\n  source_id,\n  campaign_id,\n  stage_id: '67a0f8b0e4c0d80018789f11'\n}}];\n"
      },
