    {
      "parameters": {
        "jsCode": "\nconst lead   = $('CHECAR EMPRESA EXISTE').first().json;\nconst newOrg = $json.body ?? $json;\nconst orgId  = newOrg._id ?? newOrg.id ?? newOrg.organization?._id ?? newOrg.organization?.id;\nreturn [{json: { ...lead, org_id: orgId, org_exists: false }}];\n"
      },
