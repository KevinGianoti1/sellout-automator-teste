      "parameters": {
        "jsCode": "\nconst body = $input.first().json.body ?? $input.first().json;\n\nconst nome        = String(body.name        ?? '').trim();\nconst tel         = String(body.phone       ?? '').trim();\nconst cnpj        = String(body.cnpj        ?? '').replace(/\\D/g, '');\nconst origem      = String(body.origin      ?? '').trim();\n\n// Primeira mensagem do cliente (vem com texto do anúncio ex: \"vim do utm_campaign\")\nconst origemAnuncio = String(body.first_message ?? body.utm_campaign ?? body.ad_name ?? '').trim();\n\nif (!nome || !tel || cnpj.length !== 14 || !origem) {\n  throw new Error(`Campos obrigatórios faltando | nome:${nome} | tel:${tel} | cnpj:${cnpj} | origem:${origem}`);\n}\n\nreturn [{json: {\n  name:           nome,\n  phone:          tel,\n  cnpj:           cnpj,\n  origin:         origem,\n  origem_anuncio: origemAnuncio || origem,\n  email:          String(body.email   ?? '').trim(),\n  cliente:        String(body.cliente ?? 'Não informado').trim(),\n  produto:        String(body.produto ?? 'Não informado').trim(),\n  quantidade:     String(body.quantidade ?? 'Não informado').trim()\n}}];\n"
      },
