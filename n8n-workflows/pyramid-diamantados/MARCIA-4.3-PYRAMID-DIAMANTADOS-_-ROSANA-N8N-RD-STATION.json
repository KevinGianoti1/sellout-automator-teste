    {
      "parameters": {
        "jsCode": "\nconst src  = $json.body?.cnae_fiscal !== undefined ? $json.body : $json;\nconst lead = $('VALIDAÇÃO CAMPOS').first().json;\n\n// CNAE vem separado: código numérico e descrição em texto\nconst principalCodigo = String(src.cnae_fiscal              ?? '').trim();\nconst principalDesc   = String(src.cnae_fiscal_descricao    ?? '').trim();\nconst secundarios     = Array.isArray(src.cnaes_secundarios) ? src.cnaes_secundarios : [];\nconst secundariosList = secundarios.map(x => `${x.codigo} - ${x.descricao}`).join('\\n');\n\nconst razaoSocial = String(src.razao_social  ?? src.nome_fantasia ?? lead.name).trim();\nconst municipio   = String(src.municipio     ?? '').trim();\nconst uf          = String(src.uf            ?? '').trim();\nconst porte       = String(src.porte         ?? '').trim();\n\nconst cnaeNoteText =\n  `CNAE enriquecido automaticamente pela Márcia\\n` +\n  `Principal: ${principalCodigo} - ${principalDesc}\\n` +\n  `Secundários:\\n${secundariosList || 'Nenhum'}\\n` +\n  `Fonte: BrasilAPI`;\n\nconst resumoLead =\n  `Lead qualificado pela Márcia | Pyramid Diamantados\\n` +\n  `Nome: ${lead.name}\\n` +\n  `Telefone: ${lead.phone}\\n` +\n  `Email: ${lead.email || 'Não informado'}\\n` +\n  `CNPJ: ${lead.cnpj}\\n` +\n  `Razão Social: ${razaoSocial}\\n` +\n  `Município: ${municipio} - ${uf}\\n` +\n  `Porte: ${porte}\\n` +\n  `Perfil: ${lead.cliente}\\n` +\n  `Origem: ${lead.origin}\\n` +\n  `Anúncio/Campanha: ${lead.origem_anuncio}\\n` +\n  `Produto: ${lead.produto}\\n` +\n  `Quantidade: ${lead.quantidade}`;\n\nreturn [{json: {\n  ...lead,\n  razao_social:             razaoSocial,\n  municipio, uf, porte,\n  cnae_principal_codigo:    principalCodigo,\n  cnae_principal_descricao: principalDesc,\n  cnaes_secundarios_lista:  secundariosList,\n  cnae_note_text:           cnaeNoteText,\n  resumo_lead:              resumoLead\n}}];\n"
      },
      "id": "0a21cd64-4645-4a4b-ac35-3dbb4e3890fe",
      "name": "TRATAMENTO CNAE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2320,
        592
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst cnaesValidos = new Set([\"4744001\", \"4744099\", \"4672900\", \"4742300\", \"4679699\", \"4673700\", \"4663000\", \"4744003\", \"4744005\", \"4789099\", \"4642702\", \"4755502\", \"4679601\", \"7739099\", \"4759899\", \"4741500\", \"4661300\", \"4662100\", \"4679604\", \"4669999\", \"7319002\", \"4613300\"]);\nconst principal    = String($json.cnae_principal_codigo ?? '').trim();\nconst secundarios  = String($json.cnaes_secundarios_lista ?? '')\n  .split('\\n').map(l => l.split(' - ')[0].trim()).filter(Boolean);\n\nconst cnaesDoLead  = [principal, ...secundarios].filter(Boolean);\nconst compativeis  = cnaesDoLead.filter(c => cnaesValidos.has(c));\nconst isAprovado   = compativeis.length > 0;\n\nconst mensagemBreakUp =\n  `Oi! Tudo bem? 😊 Aqui é a Márcia, da Pyramid Diamantados!\\n\\n` +\n  `Verifiquei o CNAE da sua empresa e, por enquanto, ele não está dentro dos segmentos que atendemos diretamente.\\n\\n` +\n  `Trabalhamos com empresas dos setores de ferragens, ferramentas, materiais de construção, ` +\n  `material elétrico e equipamentos industriais.\\n\\n` +\n  `Se futuramente atuarem nessas frentes, será um prazer retomar o papo! 😊\\n\\n` +\n  `Abraço e sucesso por aí!\\n— Márcia | Inteligência Comercial Pyramid Diamantados`;\n\nreturn [{json: {\n  ...$json,\n  status: isAprovado ? 'Aprovado' : 'Reprovado',\n  cnaes_compativeis: compativeis,\n  mensagem_break_up: mensagemBreakUp\n}}];\n"
      },
