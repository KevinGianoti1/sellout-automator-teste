    {
      "parameters": {
        "jsCode": "\n// Para evitar esta chamada GET /users a cada execução, preencha OWNER_ID_BEATRIZ\n// com o ID fixo encontrado na 1ª execução e o sistema usará o valor fixo.\nconst OWNER_ID_BEATRIZ = ''; // ex: '64b82d4019f6fc001c8c89ba'\nconst OWNER_NAME = 'BEATRIZ';\nconst resp  = $json.users ?? $json;\nconst users = Array.isArray(resp) ? resp : [];\nconst found = users.find(u =>\n  String(u.name ?? u.full_name ?? '').trim().toUpperCase().includes(OWNER_NAME)\n);\nif (!found) throw new Error(`Usuário ${OWNER_NAME} não encontrado no RD Station`);\nreturn [{json: { owner_id: OWNER_ID_BEATRIZ || (found._id ?? found.id), owner_name: found.name ?? found.full_name }}];\n"
