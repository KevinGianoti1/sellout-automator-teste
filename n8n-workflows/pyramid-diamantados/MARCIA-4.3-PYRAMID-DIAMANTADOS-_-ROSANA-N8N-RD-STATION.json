    {
      "parameters": {
        "jsCode": "\nconst lead      = $('DEFINIR FONTE E CAMPANHA').first().json;\nconst respOrgs  = $json.body ?? $json;\nconst orgs      = Array.isArray(respOrgs.organizations) ? respOrgs.organizations\n                : Array.isArray(respOrgs) ? respOrgs : [];\n\n// Busca por razão social (normaliza para comparação)\nconst normalize = s => String(s ?? '').trim().toLowerCase()\n  .normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n\nconst targetName = normalize(lead.razao_social);\nconst found = orgs.find(o => normalize(o.name) === targetName);\n\nreturn [{json: {\n  ...lead,\n  org_exists:  !!found,\n  org_id:      found ? (found._id ?? found.id) : null,\n  org_name_rd: found ? found.name : null\n}}];\n"
      },
